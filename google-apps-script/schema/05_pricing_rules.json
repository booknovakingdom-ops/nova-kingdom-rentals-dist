{
  "tab_name": "Config_PricingRules",
  "description": "All fee and discount rules evaluated by QuoteEngine. Rules are ordered by priority — lower number = evaluated first. QuoteEngine applies ALL matching rules in priority order.",
  "version_controlled": true,
  "columns": [
    { "name": "rule_id",           "type": "STRING",  "required": true,  "description": "Unique rule ID. Format: {tenant_id}-PR-{NNN}" },
    { "name": "tenant_id",         "type": "STRING",  "required": true,  "description": "Tenant this rule applies to" },
    { "name": "rule_type",         "type": "ENUM",    "required": true,  "description": "travel | extension | surcharge | deposit | attendant | damage | discount", "enum": ["travel", "extension", "surcharge", "deposit", "attendant", "damage", "discount"] },
    { "name": "rule_name",         "type": "STRING",  "required": true,  "description": "Human-readable rule name" },
    { "name": "trigger_field",     "type": "STRING",  "required": false, "description": "Quote field that triggers this rule (e.g. 'distance_km', 'payment_method', 'discount_pct')" },
    { "name": "trigger_operator",  "type": "ENUM",    "required": false, "description": "gt | gte | lt | lte | eq | in | always", "enum": ["gt", "gte", "lt", "lte", "eq", "in", "always"] },
    { "name": "trigger_value",     "type": "STRING",  "required": false, "description": "Value to compare against. Comma-separated for 'in' operator. Null for 'always'" },
    { "name": "calc_type",         "type": "ENUM",    "required": true,  "description": "flat | percent | per_unit_over_threshold", "enum": ["flat", "percent", "per_unit_over_threshold"] },
    { "name": "calc_value",        "type": "NUMBER",  "required": true,  "description": "Amount or rate. For percent: decimal (0.05 = 5%). For per_unit_over_threshold: fee per unit" },
    { "name": "calc_basis",        "type": "STRING",  "required": false, "description": "What the calc_value is applied to. E.g. 'quote_total', 'chargeable_km', 'hours'" },
    { "name": "threshold_value",   "type": "NUMBER",  "required": false, "description": "For per_unit_over_threshold: the threshold. E.g. 15 for free_km" },
    { "name": "applies_to",        "type": "STRING",  "required": false, "description": "Null = all units. Comma-separated unit_ids or package_ids to restrict" },
    { "name": "requires_approval", "type": "BOOLEAN", "required": true,  "description": "If true, applying this rule requires owner approval" },
    { "name": "priority",          "type": "INTEGER", "required": true,  "description": "Evaluation order. Lower = evaluated first" },
    { "name": "status",            "type": "ENUM",    "required": true,  "description": "active | archived", "enum": ["active", "archived"] },
    { "name": "version",           "type": "INTEGER", "required": true,  "description": "Row version number" },
    { "name": "effective_from",    "type": "DATE",    "required": true,  "description": "Date this version became effective (YYYY-MM-DD)" },
    { "name": "effective_to",      "type": "DATE",    "required": false, "description": "Null = currently active" },
    { "name": "changed_by",        "type": "STRING",  "required": true,  "description": "Who made this change" },
    { "name": "changed_at",        "type": "DATETIME","required": true,  "description": "ISO timestamp of change" }
  ],
