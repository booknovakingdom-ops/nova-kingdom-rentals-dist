{
  "tab_name": "Config_OpsControls",
  "description": "Runtime control flags for each tenant. Read at the start of every worker script execution. Change here to enable/disable features without code deployment.",
  "version_controlled": false,
  "notes": "Not version-controlled via effective_from/to — these are live operational toggles. Full change history is preserved in Ops_BookingLifecycleLog event type CONTROL_CHANGED.",
  "columns": [
    { "name": "control_id",    "type": "STRING",  "required": true,  "description": "Unique control ID. Format: {tenant_id}-OC-{NNN}" },
    { "name": "tenant_id",     "type": "STRING",  "required": true,  "description": "Tenant this control applies to" },
    { "name": "control_key",   "type": "STRING",  "required": true,  "description": "Machine-readable key used in code (e.g. 'simulation_mode')" },
    { "name": "control_value", "type": "STRING",  "required": true,  "description": "String value. Code parses to correct type per data_type." },
    { "name": "data_type",     "type": "ENUM",    "required": true,  "description": "boolean | string | number | json", "enum": ["boolean", "string", "number", "json"] },
    { "name": "description",   "type": "STRING",  "required": true,  "description": "What this control does and when to change it" },
    { "name": "status",        "type": "ENUM",    "required": true,  "description": "active | disabled", "enum": ["active", "disabled"] },
    { "name": "changed_by",    "type": "STRING",  "required": true,  "description": "Who last changed this value" },
    { "name": "changed_at",    "type": "DATETIME","required": true,  "description": "ISO timestamp of last change" }
  ],
