{
  "tab_name": "Config_PackageComponents",
  "description": "Join table: which unit_ids are included in each package. Multiple rows per package. Not version-controlled individually — package version covers this.",
  "version_controlled": false,
  "columns": [
    { "name": "component_id",  "type": "STRING",  "required": true,  "description": "Unique row ID. Format: {package_id}-C-{NNN}" },
    { "name": "package_id",    "type": "STRING",  "required": true,  "description": "Foreign key → Config_Packages.package_id" },
    { "name": "tenant_id",     "type": "STRING",  "required": true,  "description": "Tenant (denormalized for query convenience)" },
    { "name": "unit_id",       "type": "STRING",  "required": true,  "description": "Foreign key → Config_InventoryUnits.unit_id" },
    { "name": "unit_name",     "type": "STRING",  "required": true,  "description": "Denormalized unit name for readability" },
    { "name": "quantity",      "type": "INTEGER", "required": true,  "description": "How many of this unit type are included (usually 1)" },
    { "name": "notes",         "type": "STRING",  "required": false, "description": "Any per-component notes (e.g. 'optional add-on')" }
  ],
