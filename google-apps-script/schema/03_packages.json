{
  "tab_name": "Config_Packages",
  "description": "Named bundles of units sold at a package price. Components defined in Config_PackageComponents. Packages can be priced independently of the sum of their unit prices.",
  "version_controlled": true,
  "columns": [
    { "name": "package_id",     "type": "STRING",  "required": true,  "description": "Unique package ID. Format: {tenant_id}-PKG-{NNN}" },
    { "name": "tenant_id",      "type": "STRING",  "required": true,  "description": "Tenant this package belongs to" },
    { "name": "package_name",   "type": "STRING",  "required": true,  "description": "Display name shown in quotes" },
    { "name": "package_type",   "type": "ENUM",    "required": true,  "description": "bundle | school | community | custom", "enum": ["bundle", "school", "community", "custom"] },
    { "name": "base_price",     "type": "NUMBER",  "required": true,  "description": "Package price (may differ from sum of component unit prices)" },
    { "name": "default_hours",  "type": "NUMBER",  "required": true,  "description": "Duration included in base_price" },
    { "name": "description",    "type": "STRING",  "required": false, "description": "Customer-facing description" },
    { "name": "tags",           "type": "STRING",  "required": false, "description": "Comma-separated tags" },
    { "name": "status",         "type": "ENUM",    "required": true,  "description": "active | draft | archived", "enum": ["active", "draft", "archived"] },
    { "name": "version",        "type": "INTEGER", "required": true,  "description": "Row version number" },
    { "name": "effective_from", "type": "DATE",    "required": true,  "description": "Date this version became effective (YYYY-MM-DD)" },
    { "name": "effective_to",   "type": "DATE",    "required": false, "description": "Null = currently active" },
    { "name": "changed_by",     "type": "STRING",  "required": true,  "description": "Who made this change" },
    { "name": "changed_at",     "type": "DATETIME","required": true,  "description": "ISO timestamp of change" }
  ],
