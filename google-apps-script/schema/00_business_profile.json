{
  "tab_name": "Config_BusinessProfile",
  "description": "One row per tenant. All business-level defaults and configuration.",
  "version_controlled": true,
  "columns": [
    { "name": "tenant_id",            "type": "STRING",  "required": true,  "description": "Unique tenant identifier. NKR = 'nkr'" },
    { "name": "business_name",        "type": "STRING",  "required": true,  "description": "Full legal or operating business name" },
    { "name": "owner_name",           "type": "STRING",  "required": true,  "description": "Primary owner/operator name" },
    { "name": "phone",                "type": "STRING",  "required": true,  "description": "Primary contact phone" },
    { "name": "email",                "type": "STRING",  "required": true,  "description": "Primary business email" },
    { "name": "city",                 "type": "STRING",  "required": true,  "description": "Operating city" },
    { "name": "province",             "type": "STRING",  "required": true,  "description": "Province/state" },
    { "name": "country",              "type": "STRING",  "required": true,  "description": "Country code (e.g. CA)" },
    { "name": "timezone",             "type": "STRING",  "required": true,  "description": "IANA timezone (e.g. America/Halifax)" },
    { "name": "currency",             "type": "STRING",  "required": true,  "description": "ISO currency code (e.g. CAD)" },
    { "name": "deposit_rate",         "type": "NUMBER",  "required": true,  "description": "Decimal deposit rate (e.g. 0.30 = 30%)" },
    { "name": "free_travel_km",       "type": "NUMBER",  "required": true,  "description": "Kilometres included free before travel fee starts" },
    { "name": "travel_fee_per_km",    "type": "NUMBER",  "required": true,  "description": "Travel fee rate per km beyond free_travel_km" },
    { "name": "card_surcharge_rate",  "type": "NUMBER",  "required": true,  "description": "Credit card processing surcharge (decimal, e.g. 0.05 = 5%)" },
    { "name": "attendant_rate_hr",    "type": "NUMBER",  "required": true,  "description": "Hourly rate for event attendant/supervisor" },
    { "name": "wind_limit_kmh",       "type": "NUMBER",  "required": true,  "description": "Maximum wind speed in km/h for safe operation" },
    { "name": "silly_string_fee",     "type": "NUMBER",  "required": true,  "description": "Flat fee charged if silly string damage found on unit" },
    { "name": "extension_fee",        "type": "NUMBER",  "required": true,  "description": "Flat fee per booking extension request" },
    { "name": "min_discount_approval","type": "NUMBER",  "required": true,  "description": "Discount % above which owner approval is required (e.g. 0.10 = 10%)" },
    { "name": "hst_registered",       "type": "BOOLEAN", "required": true,  "description": "Whether business is HST registered. FALSE = never add HST" },
    { "name": "season_start_month",   "type": "INTEGER", "required": false, "description": "Month number when season opens (1=Jan). Null = year-round" },
    { "name": "season_end_month",     "type": "INTEGER", "required": false, "description": "Month number when season closes. Null = year-round" },
    { "name": "google_review_url",    "type": "STRING",  "required": false, "description": "Google review link for post-event requests" },
    { "name": "service_area_km",      "type": "NUMBER",  "required": false, "description": "Maximum delivery radius in km. Null = no hard limit" },
    { "name": "status",               "type": "ENUM",    "required": true,  "description": "active | archived", "enum": ["active", "archived"] },
    { "name": "version",              "type": "INTEGER", "required": true,  "description": "Row version number, starts at 1" },
    { "name": "effective_from",       "type": "DATE",    "required": true,  "description": "Date this version became effective (YYYY-MM-DD)" },
    { "name": "effective_to",         "type": "DATE",    "required": false, "description": "Date this version expired. Null = currently active" },
    { "name": "changed_by",           "type": "STRING",  "required": true,  "description": "Who made this change (owner name or 'system')" },
    { "name": "changed_at",           "type": "DATETIME","required": true,  "description": "ISO timestamp of change" }
  ],
