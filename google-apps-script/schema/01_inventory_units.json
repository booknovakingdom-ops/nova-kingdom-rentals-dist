{
  "tab_name": "Config_InventoryUnits",
  "description": "Catalogue of rentable unit types. One row per unit type. Does not track individual physical copies (see Config_PhysicalAssets).",
  "version_controlled": true,
  "columns": [
    { "name": "unit_id",           "type": "STRING",  "required": true,  "description": "Unique unit type ID. Format: {tenant_id}-U-{NNN}" },
    { "name": "tenant_id",         "type": "STRING",  "required": true,  "description": "Tenant this unit belongs to" },
    { "name": "unit_name",         "type": "STRING",  "required": true,  "description": "Display name shown in quotes and comms" },
    { "name": "unit_type",         "type": "ENUM",    "required": true,  "description": "combo | slide | obstacle | axe | game | other", "enum": ["combo", "slide", "obstacle", "axe", "game", "other"] },
    { "name": "base_price",        "type": "NUMBER",  "required": true,  "description": "Standard rental price for default duration" },
    { "name": "default_hours",     "type": "NUMBER",  "required": true,  "description": "Duration included in base_price" },
    { "name": "min_age",           "type": "INTEGER", "required": false, "description": "Minimum recommended rider age" },
    { "name": "max_age",           "type": "INTEGER", "required": false, "description": "Maximum recommended rider age" },
    { "name": "space_length_ft",   "type": "NUMBER",  "required": false, "description": "Required setup space length in feet" },
    { "name": "space_width_ft",    "type": "NUMBER",  "required": false, "description": "Required setup space width in feet" },
    { "name": "space_height_ft",   "type": "NUMBER",  "required": false, "description": "Required clearance height in feet" },
    { "name": "power_required",    "type": "BOOLEAN", "required": true,  "description": "Whether blower/power outlet is required" },
    { "name": "setup_time_min",    "type": "INTEGER", "required": false, "description": "Estimated setup time in minutes" },
    { "name": "teardown_time_min", "type": "INTEGER", "required": false, "description": "Estimated teardown time in minutes" },
    { "name": "description",       "type": "STRING",  "required": false, "description": "Short customer-facing description" },
    { "name": "tags",              "type": "STRING",  "required": false, "description": "Comma-separated tags (e.g. toddler,combo,slide)" },
    { "name": "availability_note", "type": "STRING",  "required": false, "description": "Freeform note on availability (e.g. 'Arriving June 2026')" },
    { "name": "status",            "type": "ENUM",    "required": true,  "description": "active | coming_soon | retired", "enum": ["active", "coming_soon", "retired"] },
    { "name": "version",           "type": "INTEGER", "required": true,  "description": "Row version number" },
    { "name": "effective_from",    "type": "DATE",    "required": true,  "description": "Date this version became effective (YYYY-MM-DD)" },
    { "name": "effective_to",      "type": "DATE",    "required": false, "description": "Date this version expired. Null = currently active" },
    { "name": "changed_by",        "type": "STRING",  "required": true,  "description": "Who made this change" },
    { "name": "changed_at",        "type": "DATETIME","required": true,  "description": "ISO timestamp of change" }
  ],
