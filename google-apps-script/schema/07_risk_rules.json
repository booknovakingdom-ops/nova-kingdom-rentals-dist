{
  "tab_name": "Config_RiskRules",
  "description": "Rules evaluated post-AI-classification. Any matching rule can override the AI decision to MANUAL_REVIEW or ESCALATE. RiskEvaluator runs all active rules against the Context Bundle after AI Call #1.",
  "version_controlled": true,
  "columns": [
    { "name": "rule_id",            "type": "STRING",  "required": true,  "description": "Unique rule ID. Format: {tenant_id}-RR-{NNN}" },
    { "name": "tenant_id",          "type": "STRING",  "required": true,  "description": "Tenant this rule applies to" },
    { "name": "rule_name",          "type": "STRING",  "required": true,  "description": "Short descriptive rule name" },
    { "name": "condition_field",    "type": "STRING",  "required": true,  "description": "Field in Context Bundle or AI output to check (e.g. 'intent', 'email_body_contains', 'confidence')" },
    { "name": "condition_operator", "type": "ENUM",    "required": true,  "description": "eq | in | contains | lt | lte | is_true | is_false", "enum": ["eq", "in", "contains", "lt", "lte", "is_true", "is_false"] },
    { "name": "condition_value",    "type": "STRING",  "required": false, "description": "Value to match. Comma-separated for 'in'. Null for is_true/is_false." },
    { "name": "risk_action",        "type": "ENUM",    "required": true,  "description": "manual_review | escalate | no_draft | flag_only", "enum": ["manual_review", "escalate", "no_draft", "flag_only"] },
    { "name": "severity",           "type": "ENUM",    "required": true,  "description": "low | medium | high | critical", "enum": ["low", "medium", "high", "critical"] },
    { "name": "reason",             "type": "STRING",  "required": true,  "description": "Explanation written to Manual Review log and trace" },
    { "name": "notify_owner",       "type": "BOOLEAN", "required": true,  "description": "If true, owner is notified immediately (future: push notification or email)" },
    { "name": "status",             "type": "ENUM",    "required": true,  "description": "active | archived", "enum": ["active", "archived"] },
    { "name": "version",            "type": "INTEGER", "required": true,  "description": "Row version number" },
    { "name": "effective_from",     "type": "DATE",    "required": true,  "description": "Date this version became effective (YYYY-MM-DD)" },
    { "name": "effective_to",       "type": "DATE",    "required": false, "description": "Null = currently active" },
    { "name": "changed_by",         "type": "STRING",  "required": true,  "description": "Who made this change" },
    { "name": "changed_at",         "type": "DATETIME","required": true,  "description": "ISO timestamp of change" }
  ],
