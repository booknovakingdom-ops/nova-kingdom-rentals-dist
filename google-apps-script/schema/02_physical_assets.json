{
  "tab_name": "Config_PhysicalAssets",
  "description": "Individual physical copies of inventory units. Enables multi-copy tracking and per-asset maintenance history. Required for double-booking prevention when fleet expands.",
  "version_controlled": false,
  "notes": "Not version-controlled via effective_from/to because condition and status change frequently. All changes are appended as audit events in the Ops_BookingLifecycleLog instead.",
  "columns": [
    { "name": "asset_id",             "type": "STRING",  "required": true,  "description": "Unique physical asset ID. Format: {tenant_id}-A-{NNN}" },
    { "name": "tenant_id",            "type": "STRING",  "required": true,  "description": "Tenant this asset belongs to" },
    { "name": "unit_id",              "type": "STRING",  "required": true,  "description": "Foreign key → Config_InventoryUnits.unit_id" },
    { "name": "unit_name",            "type": "STRING",  "required": true,  "description": "Denormalized name for readability" },
    { "name": "serial_number",        "type": "STRING",  "required": false, "description": "Manufacturer serial number if available" },
    { "name": "purchase_date",        "type": "DATE",    "required": false, "description": "Date acquired (YYYY-MM-DD)" },
    { "name": "condition",            "type": "ENUM",    "required": true,  "description": "excellent | good | fair | needs_repair | retired", "enum": ["excellent", "good", "fair", "needs_repair", "retired"] },
    { "name": "last_inspection_date", "type": "DATE",    "required": false, "description": "Date of last formal inspection" },
    { "name": "next_inspection_date", "type": "DATE",    "required": false, "description": "Date next inspection is due" },
    { "name": "storage_location",     "type": "STRING",  "required": false, "description": "Where unit is stored when not deployed" },
    { "name": "notes",                "type": "STRING",  "required": false, "description": "Maintenance notes, known issues, repair history summary" },
    { "name": "status",               "type": "ENUM",    "required": true,  "description": "available | deployed | in_repair | retired", "enum": ["available", "deployed", "in_repair", "retired"] },
    { "name": "changed_by",           "type": "STRING",  "required": true,  "description": "Who last updated this row" },
    { "name": "changed_at",           "type": "DATETIME","required": true,  "description": "ISO timestamp of last change" }
  ],
